{
  "openapi": "3.0.0",
  "info": {
    "title": "Hostel Hub API",
    "description": "Production API for Hostel Management System (Flutter/Web)",
    "version": "2.0.0"
  },
  "servers": [
    { "url": "https://hostel-hub-1-0835.onrender.com/api" }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login User",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/buildings": {
      "get": {
        "tags": ["Buildings"],
        "summary": "List all buildings",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/bookings": {
      "post": {
        "tags": ["Bookings"],
        "summary": "Create booking",
        "security": [{ "bearerAuth": [] }],
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/complaints": {
      "post": {
        "tags": ["Complaints"],
        "summary": "Raise a complaint",
        "security": [{ "bearerAuth": [] }],
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/dashboard/summary": {
      "get": {
        "tags": ["Dashboard"],
        "summary": "Get KPI Summary",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
