        { "name": "Get My Bookings", "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{token}}"}], "url": { "raw": "{{baseUrl}}/api/bookings/me", "host": ["{{baseUrl}}"], "path": ["api","bookings","me"] } } },
        { "name": "Create Booking", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{token}}"}], "url": { "raw": "{{baseUrl}}/api/bookings", "host": ["{{baseUrl}}"], "path": ["api","bookings"] }, "body": { "mode": "raw", "raw": "{\n  \"buildingId\": \"BUILDING_ID\",\n  \"tenantId\": \"TENANT_ID\",\n  \"category\": \"Standard\",\n  \"moveInDate\": \"2026-07-01\",\n  \"securityDeposit\": 5000,\n  \"onboardingFee\": 500,\n  \"totalAmount\": 8000,\n  \"method\": \"UPI\",\n  \"sharingType\": 2,\n  \"guestName\": \"Test Tenant\",\n  \"email\": \"tenant@example.com\",\n  \"phone\": \"+919876543210\"\n}" } } }
      ]
    },
    {
      "name": "Payments (Protected)",
      "item": [
        { "name": "Get My Payments", "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{token}}"}], "url": { "raw": "{{baseUrl}}/api/payments", "host": ["{{baseUrl}}"], "path": ["api","payments"] } } }
      ]
    },
    {
      "name": "Complaints (Protected)",
      "item": [
        { "name": "Get My Complaints", "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{token}}"}], "url": { "raw": "{{baseUrl}}/api/complaints", "host": ["{{baseUrl}}"], "path": ["api","complaints"] } } },
        { "name": "Create Complaint", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{token}}"}], "url": { "raw": "{{baseUrl}}/api/complaints", "host": ["{{baseUrl}}"], "path": ["api","complaints"] }, "body": { "mode": "raw", "raw": "{\n  \"title\": \"Water leakage\",\n  \"description\": \"Water leakage in room 204.\",\n  \"category\": \"Maintenance\",\n  \"priority\": \"High\"\n}" } } }
