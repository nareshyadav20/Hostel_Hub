        { "name": "Get Complete Tenant Profile", "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{token}}"}], "url": { "raw": "{{baseUrl}}/api/tenant-portal/complete-profile", "host": ["{{baseUrl}}"], "path": ["api","tenant-portal","complete-profile"] } } }
      ]
    },
    {
