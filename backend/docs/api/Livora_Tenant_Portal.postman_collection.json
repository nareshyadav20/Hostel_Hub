{
  "info": {
    "name": "Livora Hostel Hub Tenant Portal APIs",
    "_postman_id": "livora-hostel-hub-tenant-v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://livora-hostel-hub-1.onrender.com", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        { "name": "Register", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] }, "body": { "mode": "raw", "raw": "{\n  \"name\": \"Test Tenant\",\n  \"email\": \"tenant@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"TENANT\",\n  \"phone\": \"+919876543210\"\n}" } } },
        { "name": "Login", "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["const j = pm.response.json(); if(j.token) pm.collectionVariables.set('token', j.token);"] } }], "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }, "body": { "mode": "raw", "raw": "{\n  \"email\": \"tenant@example.com\",\n  \"password\": \"password123\"\n}" } } },
        { "name": "Send OTP (Phone)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/api/auth/send-otp", "host": ["{{baseUrl}}"], "path": ["api","auth","send-otp"] }, "body": { "mode": "raw", "raw": "{\n  \"phone\": \"+919876543210\"\n}" } } },
        { "name": "Verify OTP (Phone)", "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["const j = pm.response.json(); if(j.token) pm.collectionVariables.set('token', j.token);"] } }], "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/api/auth/verify-otp", "host": ["{{baseUrl}}"], "path": ["api","auth","verify-otp"] }, "body": { "mode": "raw", "raw": "{\n  \"phone\": \"+919876543210\",\n  \"otp\": \"123456\"\n}" } } },
        { "name": "Refresh Token", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/api/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api","auth","refresh"] }, "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{token}}\"\n}" } } },
        { "name": "Logout", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{baseUrl}}/api/auth/logout", "host": ["{{baseUrl}}"], "path": ["api","auth","logout"] } } },
        { "name": "Forgot Password", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/api/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["api","auth","forgot-password"] }, "body": { "mode": "raw", "raw": "{\n  \"email\": \"tenant@example.com\"\n}" } } }
      ]
    },
    {
      "name": "Public - Buildings",
      "item": [
        { "name": "Get All Public Buildings", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/buildings/public?limit=20&page=1", "host": ["{{baseUrl}}"], "path": ["api","buildings","public"], "query": [{"key":"limit","value":"20"},{"key":"page","value":"1"}] } } },
        { "name": "Get Public Building by ID", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/buildings/public/:id", "host": ["{{baseUrl}}"], "path": ["api","buildings","public",":id"], "variable": [{"key":"id","value":"BUILDING_ID"}] } } },
        { "name": "Get Platform Stats", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/buildings/public/stats", "host": ["{{baseUrl}}"], "path": ["api","buildings","public","stats"] } } }
      ]
