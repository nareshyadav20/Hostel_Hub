      ]
    },
    {
      "name": "Wishlist (Protected)",
      "item": [
        { "name": "Get My Wishlist", "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{token}}"}], "url": { "raw": "{{baseUrl}}/api/wishlist", "host": ["{{baseUrl}}"], "path": ["api","wishlist"] } } },
        { "name": "Add to Wishlist", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{token}}"}], "url": { "raw": "{{baseUrl}}/api/wishlist", "host": ["{{baseUrl}}"], "path": ["api","wishlist"] }, "body": { "mode": "raw", "raw": "{\n  \"hostelId\": \"BUILDING_ID\",\n  \"hostelName\": \"Sample Hostel\",\n  \"hostelLocation\": \"Hyderabad\",\n  \"hostelPrice\": 7000,\n  \"hostelRating\": 4.5,\n  \"type\": \"Boys\"\n}" } } },
