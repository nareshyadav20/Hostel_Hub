        { "name": "Get My Reviews (Protected)", "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{token}}"}], "url": { "raw": "{{baseUrl}}/api/reviews/me", "host": ["{{baseUrl}}"], "path": ["api","reviews","me"] } } }
