        { "name": "Occupancy Stats", "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{token}}"}], "url": { "raw": "{{baseUrl}}/api/dashboard/occupancy", "host": ["{{baseUrl}}"], "path": ["api","dashboard","occupancy"] } } }
