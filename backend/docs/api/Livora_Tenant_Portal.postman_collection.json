        { "name": "Get Public Hostels (alias)", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/hostels/public", "host": ["{{baseUrl}}"], "path": ["api","hostels","public"] } } },
        { "name": "Get Hostel Detail by ID", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/hostels/:hostelId", "host": ["{{baseUrl}}"], "path": ["api","hostels",":hostelId"], "variable": [{"key":"hostelId","value":"HOSTEL_ID"}] } } }
