// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mongodb"
}

enum Role {
  SUPER_ADMIN
  OWNER
  STAFF
  TENANT
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String    @unique
  password      String
  name          String
  role          Role      @default(TENANT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  ownedHostels  Hostel[]  @relation("HostelOwner")
  staffHostel   Hostel?   @relation("HostelStaff", fields: [hostelId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  hostelId      String?   @db.ObjectId
  tenantRecord  Tenant?   @relation("UserTenant")
}

model Hostel {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  address       String
  owner         User      @relation("HostelOwner", fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ownerId       String    @db.ObjectId
  
  floorMappings HostelFloorMapping[]
  staff         User[]    @relation("HostelStaff")
  complaints    Complaint[]
  foodMenus     FoodMenu[]
  
  images        String[]
  
  subscription  Subscription?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Building {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  address   String?
  images    String[]
  floors    Floor[]
}

model Floor {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  floorNumber  String
  images       String[]
  building     Building @relation(fields: [buildingId], references: [id])
  buildingId   String   @db.ObjectId
  rooms        Room[]
  hostelMappings HostelFloorMapping[]
}

model Room {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  roomNumber  String
  roomType    String
  capacity    Int
  images      String[]
  floor       Floor    @relation(fields: [floorId], references: [id])
  floorId     String   @db.ObjectId
  beds        Bed[]
}

model Bed {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  bedNumber   String
  status      String   @default("AVAILABLE") // AVAILABLE, OCCUPIED
  images      String[]
  room        Room     @relation(fields: [roomId], references: [id])
  roomId      String   @db.ObjectId
  tenant      Tenant?
}

model HostelFloorMapping {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  hostel      Hostel   @relation(fields: [hostelId], references: [id])
  hostelId    String   @db.ObjectId
  floor       Floor    @relation(fields: [floorId], references: [id])
  floorId     String   @db.ObjectId
  buildingId  String   @db.ObjectId
  
  @@unique([hostelId, floorId])
}

model Tenant {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  user      User     @relation("UserTenant", fields: [userId], references: [id])
  userId    String   @unique @db.ObjectId
  bed       Bed      @relation(fields: [bedId], references: [id])
  bedId     String   @unique @db.ObjectId
  
  payments  Payment[]
  complaints Complaint[]
  
  checkIn   DateTime @default(now())
  checkOut  DateTime?
}

model Payment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String   @db.ObjectId
  amount    Float
  status    String   // PENDING, PAID, OVERDUE
  dueDate   DateTime
  paidAt    DateTime?
  createdAt DateTime @default(now())
}

model Complaint {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED
  priority    String   @default("LOW")  // LOW, MEDIUM, HIGH, URGENT
  
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  tenantId    String   @db.ObjectId
  hostel      Hostel   @relation(fields: [hostelId], references: [id])
  hostelId    String   @db.ObjectId
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FoodMenu {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  date      DateTime
  mealType  String   // BREAKFAST, LUNCH, DINNER
  items     String   // Comma separated or JSON
  hostel    Hostel   @relation(fields: [hostelId], references: [id])
  hostelId  String   @db.ObjectId
  
  attendance Attendance[]
}

model Attendance {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  foodMenu   FoodMenu @relation(fields: [foodMenuId], references: [id])
  foodMenuId String   @db.ObjectId
  tenantId   String   @db.ObjectId
  isPresent  Boolean  @default(false)
  markedAt   DateTime @default(now())
}

model Subscription {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  hostel    Hostel   @relation(fields: [hostelId], references: [id])
  hostelId  String   @unique @db.ObjectId
  plan      String   // BASIC, PREMIUM, ENTERPRISE
  status    String   // ACTIVE, EXPIRED, CANCELLED
  validUntil DateTime
}
